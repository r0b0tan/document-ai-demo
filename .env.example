# Copy to .env and fill in your values.

# Secret API key — clients must send this in the X-API-Key header.
# Leave empty to disable authentication.
API_KEY=change-me-to-a-random-secret

# Comma-separated CORS origins (your public domain).
ALLOWED_ORIGINS=https://docai.example.com

# Which Ollama models clients may use (comma-separated).
ALLOWED_MODELS=mistral,llama3,gemma

# Rate limit for /analyze (per IP).
ANALYZE_RATE_LIMIT=5/minute
