# Copy to .env and fill in your values.

# Secret API key — clients must send this in the X-API-Key header.
# Leave empty to disable authentication.
API_KEY=change-me-to-a-random-secret

# Comma-separated CORS origins (your public domain).
ALLOWED_ORIGINS=https://docai.example.com

# LLM provider: "ollama" (local) or "groq" (cloud API).
LLM_PROVIDER=groq

# Groq API key (required when LLM_PROVIDER=groq).
# Get one free at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Which models clients may use (comma-separated). Leave empty to allow all.
ALLOWED_MODELS=

# Rate limit for /analyze (per IP).
ANALYZE_RATE_LIMIT=5/minute
